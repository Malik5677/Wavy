    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "emoji-picker-react": "^4.19.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.42.2",
    "googleapis": "^173.0.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "open": "^11.0.0",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.81.0",
    "react-hot-toast": "^2.6.0",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
