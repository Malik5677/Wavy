# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# API and authentication configuration
# Set this to the backend URL used by the frontend.
VITE_API_URL="http://localhost:3000"
# Gmail API settings for email-only OTP delivery.
# Create OAuth credentials in Google Cloud and generate a refresh token.
GMAIL_CLIENT_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID"
GMAIL_CLIENT_SECRET="YOUR_GOOGLE_OAUTH_CLIENT_SECRET"
GMAIL_REFRESH_TOKEN="YOUR_GOOGLE_REFRESH_TOKEN"
# Sender email (supported env names: GMAIL_USER_EMAIL or GMAIL_USER)
GMAIL_USER_EMAIL="your-email@gmail.com"
GMAIL_USER="your-email@gmail.com"

# JWT secret for signing tokens.
JWT_SECRET="YOUR_JWT_SECRET"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
