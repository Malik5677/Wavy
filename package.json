{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cd backend && tsx server.ts",
    "dev:backend": "cd backend && tsx server.ts",
    "dev:frontend": "cd frontend && vite",
    "build": "cd frontend && cross-env ROOT_PROJECT=true npm run build && esbuild ../backend/server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=../dist/server.cjs",
    "start": "cross-env NODE_ENV=production node dist/server.cjs",
    "preview": "cd frontend && vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
