# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# API and authentication configuration
# Set this to the backend URL used by the frontend.
VITE_API_URL="http://localhost:3000"
# SMTP settings for email-only OTP delivery. Use a free SMTP service or Gmail app password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="you@example.com"
SMTP_PASS="your-email-password"
SMTP_FROM="WaveChat <no-reply@example.com>"
# JWT secret for signing tokens.
JWT_SECRET="YOUR_JWT_SECRET"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
